rules_version = '2';

// ---------------------------------------------------------------------------
// This app reads and writes Firestore exclusively through the Firebase Admin
// SDK on the server (see lib/firebase/admin.ts, lib/services/*), which
// bypasses these rules entirely. The rules below are defense-in-depth: they
// lock down *direct* client SDK access in case it is ever introduced, and
// implement the access model described in the project spec:
//   - Admins (custom claim `admin: true`) have full read/write access.
//   - The public invitation page may read a single guest by id.
//   - A guest may update only their own RSVP fields, and only once.
// ---------------------------------------------------------------------------

function isAdmin() {
  return request.auth != null && request.auth.token.admin == true;
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /guests/{guestId} {
      // Public invitation pages read a single guest by id to render the
      // personalized invitation.
      allow get: if true;
      // No direct listing of the guest collection from clients.
      allow list: if isAdmin();

      allow create, delete: if isAdmin();

      // Admins can update anything. A guest (unauthenticated) may only set
      // their own RSVP fields, and only while the response is still pending.
      allow update: if isAdmin()
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['responseStatus', 'respondedAt'])
          && resource.data.responseStatus == 'pending'
          && request.resource.data.responseStatus in ['accepted', 'rejected']
        );
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{document=**} {
      allow read, write: if isAdmin();
    }

    match /wishes/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
